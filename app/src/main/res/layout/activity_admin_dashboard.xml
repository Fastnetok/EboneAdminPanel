<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="95dp"
        android:background="#0D47A1"
        android:gravity="center_vertical"
        android:paddingTop="32dp"
        android:paddingStart="15dp"
        android:paddingEnd="15dp">

        <TextView
            android:id="@+id/menuButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☰"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="15dp"
            android:text="EBONE ADMIN PANEL"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/notificationButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔔"
            android:textSize="22sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="15dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/totalComplaintText"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="#2962FF"
            android:gravity="center"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pendingComplaintText"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="#E53935"
            android:gravity="center"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/inProgressText"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="#FB8C00"
            android:gravity="center"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/resolvedText"
            android:layout_width="0dp"
            android:layout_height="95dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="#43A047"
            android:gravity="center"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LIVE EMPLOYEE TRACKING"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="#444444"
        android:paddingStart="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp" />

    <fragment
        android:id="@+id/dashboardMap"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="460dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp" />

    <TextView
        android:id="@+id/onlineEmployeesText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:text="🟢 Online Employees (0)"
        android:textColor="#444444"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/onlineEmployeesNames"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="42dp"
        android:text=""
        android:textColor="#555555"
        android:textSize="17sp" />

    <TextView
        android:id="@+id/offlineEmployeesText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:text="🔴 Offline Employees (0)"
        android:textColor="#444444"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/offlineEmployeesNames"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="42dp"
        android:text=""
        android:textColor="#555555"
        android:textSize="17sp" />

</LinearLayout>
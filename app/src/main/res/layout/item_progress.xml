<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/employeeNameText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Abbas"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"/>

    <TextView
        android:id="@+id/userIdText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="abid"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/addressText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bazaar"/>

    <TextView
        android:id="@+id/phoneText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="03004561236"/>

    <TextView
        android:id="@+id/assignedText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Assigned: 14 Jun 2026 / 09:15 AM"
        android:textStyle="bold"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/runningTimeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Running : 2 Hours"
            android:textColor="#FB8C00"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"/>

        <!--
            seenTimeText aur seenStatusIcon ab dynamic hain.
            In ki Text/Icon/Visibility ProgressAdapter.kt se
            complaint.seenByEmployee aur complaint.seenTime
            ke mutabiq set hoti hai — koi hardcoded value nahi.
        -->
        <TextView
            android:id="@+id/seenTimeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_toStartOf="@id/seenStatusIcon"
            android:layout_marginEnd="4dp"
            android:layout_centerVertical="true"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/seenStatusIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_single_tick"
            android:visibility="visible" />

    </RelativeLayout>

</LinearLayout>
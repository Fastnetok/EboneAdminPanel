<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/menuAddComplaint"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:background="#FFFFFF"
            android:text="Add Complaint"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/menuPendingDevices"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:background="#F5F5F5"
            android:text="Pending Devices"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/menuAllEmployees"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:background="#FFFFFF"
            android:text="All Employees"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/menuGeoFence"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:background="#F5F5F5"
            android:text="Geo Fence"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/menuComplaints"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:background="#FFFFFF"
            android:text="Complaints"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/menuAssignedComplaints"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:background="#F5F5F5"
            android:text="Assigned Complaints"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/menuReports"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:background="#FFFFFF"
            android:text="Reports"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/menuSettings"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:background="#F5F5F5"
            android:text="Settings"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/menuSuperAdmin"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:background="#FFF3E0"
            android:text="Super Admin Panel"
            android:textStyle="bold"
            android:textSize="18sp" />

    </LinearLayout>
</ScrollView>
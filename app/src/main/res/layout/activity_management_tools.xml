<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#0D47A1"
        android:gravity="center"
        android:paddingTop="25dp"
        android:text="MANAGEMENT TOOLS"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/filterButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="10dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:text="⚙️  Filter Complaints"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/searchButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="10dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:text="🔍  Search Complaints"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/assignButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="10dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:text="🔄  Assign Complaints"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/analyticsButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="10dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:text="📊 Analytics Reports"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/importButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="10dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:text="📥  Import Data"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/exportButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="10dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:text="📤  Export Data"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/repeatButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="10dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:text="⚠️  Repeat Complaints"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/voiceButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="10dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:text="🎤  Voice Search"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/homeButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#FFFFFF"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:text="🏠  Home"
                android:textSize="18sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Set a Quick-Unlock PIN"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="4 to 6 digits — app ke dobara khulne par ye PIN ya fingerprint use hoga"
        android:textSize="13sp"
        android:layout_marginBottom="24dp" />

    <EditText
        android:id="@+id/pinInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Naya PIN"
        android:inputType="numberPassword"
        android:maxLength="6" />

    <EditText
        android:id="@+id/pinConfirmInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="PIN dobara likhein"
        android:inputType="numberPassword"
        android:maxLength="6"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/savePinButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save PIN"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/pinStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="#D32F2F" />

</LinearLayout>